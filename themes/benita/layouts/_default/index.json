{{- $pages := where .Site.RegularPages "Params.noindex" "ne" true -}}
[
  {{- range $i, $p := $pages -}}
  {{- if $i }},{{ end -}}
  {
    "url":         {{ $p.RelPermalink | jsonify }},
    "title":       {{ $p.Title | jsonify }},
    "description": {{ $p.Description | jsonify }},
    "section":     {{ $p.Section | jsonify }},
    "content":     {{ $p.Plain | truncate 500 | jsonify }}
  }
  {{- end }}
]
